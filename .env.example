RAZORPAY_KEY_ID=RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=RAZORPAY_WEBHOOK_SECRET

# Email (optional — omit EMAIL_HOST to print emails to the console in dev)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-gmail-app-password
DEFAULT_FROM_EMAIL=Claws & Crystals <your@gmail.com>
ADMIN_ORDER_EMAIL=admin@example.com

# Site (used in email links)
SITE_URL=http://127.0.0.1:8000
SITE_NAME=Claws & Crystals

# Use the same host in the browser as SITE_URL (don't mix localhost and 127.0.0.1)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
